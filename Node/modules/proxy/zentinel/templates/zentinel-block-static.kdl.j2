{# Block template: Root domain – branding assets, Matrix .well-known, landing page
   Variables: project_domain, project_name, chat_services (list)
#}
{{ project_domain }} {
    # Shared branding assets (logo, CSS, background)
    handle /branding/* {
        root * /srv/{{ project_name }}
        file_server
    }

{% for svc in chat_services %}
    # Matrix .well-known delegation for {{ svc.name }}
    handle /.well-known/matrix/* {
        reverse_proxy {{ svc.container_name }}:{{ svc.port }}
    }
{% endfor %}

    # Landing page (default handler)
    handle {
        root * /srv/{{ project_name }}/sites/landing
        file_server
    }
}
