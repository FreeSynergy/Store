{# Zentinel per-service routing block.
   Generated by FSN for each service that declares [contract.routes].
   Written by FSN on initial file creation only.
   After creation, this file is NOT managed by the deployer
   and may be modified by the Control-Plane or operator.

   Template variables (from ServiceContract + resolve.rs):
     svc.name         – instance name (e.g. "kanidm")
     svc.domain       – full service domain (e.g. "kanidm.example.com")
     svc.container    – container name (= instance name by default)
     svc.port         – internal port
     svc.upstream_tls – true → use https:// to reach the container
     svc.health_path  – health check path (optional)
     svc.routes       – list of {id, path, strip, description}
#}
{% for svc in proxy_services %}
{{ svc.domain }} {
{% if svc.routes | length == 1 and svc.routes[0].path == "/" %}
    reverse_proxy {% if svc.upstream_tls %}https://{% endif %}{{ svc.container }}:{{ svc.port }}{% if svc.upstream_tls %} {
        transport http {
            tls
            tls_insecure_skip_verify
        }
    }{% endif %}

{% else %}
{% for route in svc.routes %}
    handle {{ route.path }}* {
        reverse_proxy {% if svc.upstream_tls %}https://{% endif %}{{ svc.container }}:{{ svc.port }}{% if svc.upstream_tls %} {
            transport http {
                tls
                tls_insecure_skip_verify
            }
        }{% endif %}

    }
{% endfor %}
    handle {
        respond 404
    }
{% endif %}
}
{% endfor %}
