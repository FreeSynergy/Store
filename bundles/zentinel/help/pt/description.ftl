zentinel-bundle-description =
    O pacote Zentinel instala tanto o proxy reverso Zentinel quanto seu
    painel de controle em conjunto — a forma recomendada de configurar o
    roteamento em um novo nó FreeSynergy.

zentinel-bundle-components =
    Este pacote inclui:

    - { $link-zentinel } — o servidor proxy reverso
    - { $link-zentinel-control-plane } — a API de roteamento dinâmico

zentinel-bundle-note =
    Clique em um componente para ver sua descrição completa e opções de configuração.
