zentinel-bundle-description =
    Het Zentinel-pakket installeert zowel de Zentinel reverse proxy als het
    bijbehorende configuratiescherm samen — de aanbevolen manier om routing
    in te stellen voor een nieuw FreeSynergy-knooppunt.

zentinel-bundle-components =
    Dit pakket bevat:

    - { $link-zentinel } — de reverse proxy-server
    - { $link-zentinel-control-plane } — de API voor dynamische routing

zentinel-bundle-note =
    Klik op een component om de volledige beschrijving en configuratieopties te bekijken.
