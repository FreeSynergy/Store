init-description =
    FreeSynergy Init ist das einmalige Bootstrap-Binary für FreeSynergy.

    Lade das Binary für deine Plattform herunter, mache es ausführbar und starte es.
    Es klont das FreeSynergy Store-Repository auf dein Gerät und startet den
    Installationsassistenten — ohne Package Manager oder vorinstallierte Abhängigkeiten.

    Sobald Init abgeschlossen ist, übernimmt der Store die Installation von Node,
    Desktop und allen gewünschten Diensten.

    Init selbst wird nicht installiert — es wird nur einmalig beim ersten Setup benötigt.

init-usage =
    # Linux / macOS
    chmod +x fs-init
    ./fs-init

    # Windows
    fs-init.exe
