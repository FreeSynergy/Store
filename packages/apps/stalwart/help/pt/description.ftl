stalwart-description =
    O Stalwart é um servidor de e-mail e colaboração tudo-em-um escrito
    em Rust.

    Gerencia SMTP (entrada e saída), IMAP, JMAP, CalDAV e CardDAV em um
    único binário — sem processos separados, sem configuração complexa.
    A interface web de administração integrada permite gerenciar domínios,
    usuários e regras de entrega.

    O Stalwart integra-se com o Kanidm via OIDC para single sign-on — os
    usuários autenticam-se com suas credenciais FreeSynergy.

stalwart-features =
    - SMTP (servidor para servidor + envio de e-mail)
    - IMAP com sincronização completa de pastas
    - JMAP (API de e-mail moderna)
    - CalDAV e CardDAV (calendário e contatos)
    - Interface web de administração
    - Single sign-on OIDC via Kanidm
    - Escrito inteiramente em Rust
