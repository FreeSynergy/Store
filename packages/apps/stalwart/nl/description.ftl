stalwart-description =
    Stalwart is een alles-in-één mail- en samenwerkingsserver geschreven
    in Rust.

    Het verwerkt SMTP (inkomend en uitgaand), IMAP, JMAP, CalDAV en CardDAV
    in één enkel programma — geen aparte processen, geen complexe
    configuratie. De ingebouwde webbeheerinterface maakt het beheren van
    domeinen, gebruikers en bezorgregels mogelijk.

    Stalwart integreert met Kanidm via OIDC voor single sign-on — gebruikers
    authenticeren met hun FreeSynergy-inloggegevens.

stalwart-features =
    - SMTP (server-naar-server + mailverzending)
    - IMAP met volledige mapsynchronisatie
    - JMAP (moderne mail-API)
    - CalDAV en CardDAV (agenda en contacten)
    - Webbeheerinterface
    - OIDC single sign-on via Kanidm
    - Volledig geschreven in Rust
