forgejo-description =
    Forgejo is a lightweight, self-hosted Git service — a community-driven fork of Gitea.

    It provides everything a software team needs: code repositories, issues, pull requests,
    code review, Forgejo Actions (CI/CD), a container and package registry, and a wiki.
    Users authenticate via Kanidm using OIDC, so there is no separate user database.

forgejo-features =
    - Git repository hosting
    - Issues, pull requests, and code review
    - Forgejo Actions (GitHub Actions-compatible CI/CD)
    - Container and package registry
    - Built-in wiki
    - OIDC single sign-on via Kanidm
    - Optional PostgreSQL backend (recommended for production)
