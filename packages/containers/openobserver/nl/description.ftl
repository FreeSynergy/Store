openobserver-description =
    OpenObserve is een cloudnatief, op Rust gebaseerd observability-platform voor
    logs, metrics, traces en dashboards.

    Het is een snel alternatief met lage opslagkosten voor Elasticsearch- en Grafana-
    stacks. OpenObserve ontvangt gegevens via OpenTelemetry, ondersteunt SQL-queries
    en biedt ingebouwde dashboards, waarschuwingen en geplande rapporten. Het kan
    gecombineerd worden met de otel-collector voor een complete observability-pipeline.

openobserver-features =
    - Logs, metrics en gedistribueerde traces in één platform
    - OpenTelemetry-native ontvangst
    - SQL-query-engine voor ad-hoc-analyse
    - Ingebouwde dashboards en visualisaties
    - Waarschuwingen en geplande rapporten
    - 140x lagere opslagkosten dan Elasticsearch
    - Geschreven in Rust — lage resourcebelasting
    - S3-compatibele objectopslag voor data
