da-description =
    Danish (Dansk) language pack for FreeSynergy.

    Provides shared UI translation snippets for the desktop shell, all
    built-in applications, and the Store. Installed automatically when
    Danish is selected as the display language.

da-features =
    - actions.toml — verbs: save, cancel, delete, and more
    - labels.toml — UI labels and headings
    - nouns.toml — common nouns: file, user, package, and more
    - errors.toml — error messages
    - status.toml — status strings: running, stopped, pending, and more
    - time.toml — date and time expressions
    - plus: confirmations, notifications, phrases, validation, help
